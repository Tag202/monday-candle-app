{
  "name": "monday-integration-quickstart-app-typescript",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "scripts": {
    "dev-server": "npm run stop && npm run client-build && npx concurrently \"ts-node-dev --watch ./.env ./src/app.ts\" \"npm run expose\"",
    "build": "node_modules/.bin/tsc && cd client && npm i && npm run build && cd ..",
    "start": "node dist/app.js",
    "expose": "mapps tunnel:create -p 8080",
    "stop": "npx kill-port 8080",
    "deploy": "npm run client-build && mapps code:push",
    "client-build": "cd client && npm run build",
    "fetch:schema": "bash fetch-schema.sh",
    "codegen": "graphql-codegen",
    "fetch:generate": "npm run fetch:schema && npm run codegen",
    "test": "jest",
    "db:init": "psql -h localhost -U postgres -W -d monday_candles -f database/schema.sql",
    "db:seed": "psql -h localhost -U postgres -W -d monday_candles -f database/seed.sql"
  },
  "dependencies": {
    "@mondaydotcomorg/api": "^7.0.1",
    "@vibe/core": "^3.87.0",
    "body-parser": "^1.19.0",
    "cors": "^2.8.6",
    "dotenv": "^5.0.1",
    "express": "^4.17.1",
    "graphql": "^16.8.2",
    "graphql-request": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "monday-sdk-js": "^0.5.2",
    "pg": "^8.19.0",
    "querystring": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typescript": "^4.1.2",
    "@graphql-codegen/typescript-operations": "^4.4.0",
    "@mondaycom/apps-sdk": "^3.0.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.9",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "concurrently": "^8.2.2",
    "cross-port-killer": "^1.2.1",
    "debug": "~2.6.9",
    "eslint": "^v6.8.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "4.8"
  }
}
